{
  "name": "sprintforge-backend",
  "version": "1.0.0",
  "description": "SprintForge API Server",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec \"npx tsx src/server.ts\" --ext ts",
    "build": "npx esbuild src/server.ts --bundle --platform=node --target=node20 --outfile=dist/server.js --external:mongoose --external:bcryptjs --external:bcrypt --external:jsonwebtoken --external:express --external:socket.io --external:cors --external:helmet --external:morgan --external:dotenv --external:express-rate-limit",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts"
  },
  "keywords": [
    "agile",
    "scrum",
    "kanban",
    "project-management"
  ],
  "author": "SprintForge",
  "license": "MIT",
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mongoose": "^5.11.96",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.0",
    "@types/nodemailer": "^7.0.11",
    "@types/socket.io": "^3.0.1",
    "@types/uuid": "^10.0.0",
    "esbuild": "^0.27.5",
    "nodemon": "^3.1.14",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "express": "^4.22.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.5",
    "socket.io": "^4.8.3"
  }
}
